# DeepSeek (dev proxy in Vite, production via Netlify function)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Neon demo workspace sync (Netlify function only)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Optional legacy Neon client env vars (not used by demo-only mode)
VITE_NEON_AUTH_URL=https://your-project.neonauth.neon.build/neondb/auth
VITE_NEON_DATA_API_URL=https://your-project.apirest.neon.build/neondb/rest/v1
